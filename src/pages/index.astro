---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Yoga Studio">
  <div class="pre-loader-wrapper" data-preloader style="display:flex">
    <div class="w-layout-hflex breathe-flex" data-breathe>
      <div class="breathe-text">B</div>
      <div class="breathe-text">r</div>
      <div class="breathe-text">e</div>
      <div class="breathe-text">a</div>
      <div class="breathe-text">t</div>
      <div class="breathe-text">h</div>
      <div class="breathe-text">e</div>
      <div class="breathe-text">.</div>
      <div class="breathe-text">.</div>
      <div class="breathe-text">.</div>
    </div>
  </div>

  <header class="section_header1 background-color-grey section-light-wave">
    <Nav />
    <div class="padding-global">
      <div class="container-large">
        <div class="padding-section-large">
          <div class="header1_component">
            <div class="w-layout-grid header1_content">
              <div class="header1_content-left" data-reveal>
                <div class="margin-bottom margin-small">
                  <h1>Discover the <span class="heading-highlight">Perfect</span> Yoga Class for You</h1>
                </div>
                <p class="text-size-medium">Welcome to our yoga studio, where you'll find a variety of classes and experienced instructors to guide you on your yoga journey.</p>
                <div class="margin-top margin-medium">
                  <div class="button-group">
                    <a href="/classes" class="button w-button">Explore</a>
                  </div>
                </div>
              </div>
              <div class="header1_image-wrapper" data-reveal>
                <img loading="eager" alt="" src="/images/Hero-Back.avif" class="hero-back-image" />
                <img loading="eager" src="/images/Hero-Front_1.avif" alt="Two people in a yoga class" class="header1_image" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="wave-wrapper">
      <div class="wave-long-pattern"></div>
    </div>
  </header>

  <section class="section_layout7">
    <div class="padding-global padding-section-large">
      <div class="container-large">
        <div class="layout7_component">
          <div class="w-layout-grid layout7_content">
            <div class="layout7_content-right">
              <div class="layout7_image-wrapper" data-reveal>
                <img loading="lazy" src="/images/Home-About_1.avif" alt="A woman meditating" class="layout7_image" />
              </div>
            </div>
            <div class="layout7_content-left" data-reveal>
              <div class="margin-bottom margin-xsmall">
                <div class="text-style-tagline text-color-accent">Empower</div>
              </div>
              <div class="margin-bottom margin-small">
                <h2 class="heading-style-h2 text-color-black">Transform Your Life Through Yoga</h2>
              </div>
              <div class="margin-bottom margin-medium">
                <p class="text-size-medium text-color-black">At our yoga studio, we believe in the power of yoga to improve physical and mental well-being. Join our community and experience the benefits of a regular yoga practice. Our experienced instructors offer a variety of classes for all levels, from beginners to advanced practitioners. Whether you're looking to increase flexibility, reduce stress, or find inner peace, we have a class for you.</p>
              </div>
              <div class="margin-top margin-medium">
                <div class="button-group">
                  <a href="/classes" class="button is-secondary w-button">See Classes</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section_testimonial7 background-color-grey">
    <div class="padding-global">
      <div class="container-large">
        <div class="padding-section-large">
          <div class="margin-bottom margin-huge text-align-center">
            <h2>What customers say</h2>
            <div class="text-block">Flowga has help change many lives</div>
          </div>
          <div class="testimonial7_component">
