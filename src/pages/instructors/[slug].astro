---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { instructors } from '../../data/instructors';
import { classes } from '../../data/classes';

export function getStaticPaths() {
  return instructors.map((instructor) => ({
    params: { slug: instructor.slug },
    props: { instructor },
  }));
}

const { instructor } = Astro.props;
const theirClasses = classes.filter((c) => c.instructorSlug === instructor.slug);
---

<Layout title={`${instructor.firstName} ${instructor.lastName}`}>
  <Nav />

  <header class="section_portfolio-header6">
    <div class="portfolio-header6_component">
      <div class="portfolio-header6_image-wrapper">
        <img loading="lazy" src={instructor.image} alt={instructor.alt} class="portfolio-header6_image" />
        <img src="/images/Grey-wave.svg" loading="lazy" alt="" class="grey-wave" />
      </div>
      <div class="padding-global background-color-grey">
        <div class="container-large">
          <div class="padding-section-medium">
            <div class="w-layout-grid portfolio-header6_content-wrapper">
              <div class="portfolio-header6_content-left">
                <div class="margin-bottom margin-small">
                  <h1 class="heading-style-h1">{instructor.firstName} {instructor.lastName}</h1>
                </div>
                <div class="text-size-medium">{instructor.role}</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <section class="section_content2">
    <div class="padding-global">
      <div class="container-large">
        <div class="padding-section-large">
          <div class="content2_component">
            <div class="w-layout-grid content2_content">
              <div class="content2_content-left">
                <div class="layout12_image-wrapper">
                  <img loading="lazy" src={instructor.image} alt={instructor.alt} class="layout12_image" />
                </div>
              </div>
              <div class="content2_content-right">
                <div class="margin-bottom margin-small">
                  <h2 class="heading-style-h2">About {instructor.firstName}</h2>
                </div>
                <div class="text-rich-text w-richtext">
                  <p>{instructor.bio}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {theirClasses.length > 0 && (
    <section class="section_team17">
      <div class="padding-global">
        <div class="container-large">
          <div class="padding-section-large">
            <div class="team17_component">
              <div class="margin-bottom margin-small">
                <h2 class="heading-style-h2">Classes with {instructor.firstName}</h2>
              </div>
              <div class="w-dyn-list">
                <div role="list" class="classes-grid w-dyn-items">
                  {theirClasses.map((yogaClass) => (
                    <div role="listitem" class="w-dyn-item">
                      <div class="class-card-wrapper" style={`background-image:linear-gradient(#00000080, #00000080), url(${yogaClass.image})`}>
                        <div class="class-card-gradient"></div>
                        <div class="class-card-top-text-wrapper">
                          <div class="text-size-medium text-weight-semibold text-color-white">{yogaClass.title}</div>
                          <div class="text-size-small text-color-white">{yogaClass.tags.join(' · ')}</div>
                        </div>
                        <a href={`/classes/${yogaClass.slug}`} class="class-card-overlay w-inline-block">
                          <div class="class-card-date">
                            <div class="text-size-small text-color-white">{yogaClass.date}</div>
                            <div class="text-size-small text-color-white comma-fix-space">s,</div>
                            <div class="text-size-small text-color-white">{yogaClass.time}</div>
                          </div>
                          <div class="button is-secondary is-alternate">Learn More</div>
                        </a>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <section class="section_cta29 text-color-white background-color-accent section-dark-wave">
    <div class="padding-global">
      <div class="container-large">
        <div class="padding-section-large">
          <div class="cta29_component">
            <div class="text-align-center">
              <div class="max-width-large align-center">
                <div class="margin-bottom margin-small">
                  <h2 class="heading-style-h2 text-color-white">Elevate Your Practice</h2>
                </div>
                <p class="text-size-medium text-color-white">Discover our premium classes!</p>
                <div class="margin-top margin-medium">
                  <div class="button-group is-center">
                    <a href="/classes" class="button is-alternate w-button">Explore</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
